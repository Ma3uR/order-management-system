# Application
PORT=3000
# In production, these should be set to your actual PocketBase URL
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090
POCKETBASE_URL=http://localhost:8090

# API Keys
AI_SERVICE_API_KEY=your_ai_service_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# PocketBase Admin
NEXT_PUBLIC_POCKETBASE_ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_POCKETBASE_ADMIN_PASSWORD=your_admin_password_here

# Type Generation
PB_TYPEGEN_URL=http://localhost:8090
PB_TYPEGEN_EMAIL=admin@example.com
PB_TYPEGEN_PASSWORD=your_admin_password_here

# Marketplace APIs
ROZETKA_API_URL=https://api.rozetka.com.ua
ROZETKA_USERNAME=your_rozetka_username
ROZETKA_PASSWORD=your_rozetka_password

PROM_UA_TOKEN=your_prom_ua_token
PROMUA_API_URL=https://my.prom.ua/api/v1

EPICENTR_TOKEN=your_epicentr_token
EPICENTR_API_URL=https://merchant-api.epicentrm.com.ua

KASAVCHASNO_API_KEY=your_kasa_vchasno_api_key
KASAVCHASNO_API_URL=https://kasavchasno.com.ua/api/v1

# IMPORTANT! In production, DO NOT set this to localhost,
# or remove it entirely as it's calculated dynamically
NEXT_PUBLIC_API_URL=http://localhost:3000

# Automation Features
ENABLE_STATUS_AUTOMATION=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
ROZETKA_PROCESSING_STATUS_CODE=your_rozetka_processing_status_code_here

# Auto-Fiscal Feature
ENABLE_AUTO_FISCAL=false
CASA_VCHASNO_TOKEN=your_casa_vchasno_api_token_here
AUTO_CASHIER_NAME=AUTO

# Fiscal Automation Scheduler (New)
ENABLE_FISCAL_AUTOMATION=true
FISCAL_AUTOMATION_TEST_MODE=true
FISCAL_START_HOUR=8
FISCAL_END_HOUR=22
FISCAL_AUTO_CASHIER=AUTO-SYSTEM
FISCAL_TIMEZONE=Europe/Kiev

# Analytics and Monitoring
POSTHOG_API_KEY=your_posthog_api_key_here
POSTHOG_HOST=https://eu.i.posthog.com

# Redis Configuration for BullMQ
REDIS_URL=redis://username:password@host:port
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_DB=0
