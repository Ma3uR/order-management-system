# Application
PORT=3000
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090
POCKETBASE_URL=http://localhost:8090

# Authentication
# This should be dynamically determined in production using window.location.origin
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# API Keys
AI_SERVICE_API_KEY=your_ai_service_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# PocketBase Admin
NEXT_PUBLIC_POCKETBASE_ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_POCKETBASE_ADMIN_PASSWORD=your_admin_password_here

# Type Generation
PB_TYPEGEN_URL=http://localhost:8090
PB_TYPEGEN_EMAIL=admin@example.com
PB_TYPEGEN_PASSWORD=your_admin_password_here

# Marketplace APIs
ROZETKA_API_URL=https://api.rozetka.com.ua
ROZETKA_USERNAME=your_rozetka_username
ROZETKA_PASSWORD=your_rozetka_password

PROM_UA_TOKEN=your_prom_ua_token
PROMUA_API_URL=https://my.prom.ua/api/v1

EPICENTR_TOKEN=your_epicentr_token
EPICENTR_API_URL=https://merchant-api.epicentrm.com.ua

KASAVCHASNO_API_KEY=your_kasa_vchasno_api_key
KASAVCHASNO_API_URL=https://kasavchasno.com.ua/api/v1

# These values are automatically determined in production
NEXT_PUBLIC_API_URL=http://localhost:3000 